{
    "name": "heimseiten/contao-lesbares-css-framework-bundle",
    "type": "contao-bundle",
    "description": "Lesbares CSS-Framework für Contao samt deutschem Klassen-Selektor im Backend (Artikel & Inhaltselemente).",
    "keywords": [
        "contao",
        "css",
        "framework",
        "backend",
        "styles"
    ],
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "heimseiten.de - Webdesign aus Köln",
            "email": "info@heimseiten.de",
            "homepage": "https://www.heimseiten.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "Heimseiten\\ContaoLesbaresCssFrameworkBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Heimseiten\\ContaoLesbaresCssFrameworkBundle\\ContaoManager\\Plugin"
    }
}
